{
  "name": "kraufanding",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:critical-path": "vitest run tests/unit/architecture/post-merge-state-reconciliation.test.ts tests/integration/launch-candidate-critical-path.test.ts",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:verify": "npx ts-node scripts/verify_db.ts",
    "db:smoke": "tsx scripts/db-smoke.ts",
    "db:generate": "prisma generate",
    "prisma:generate": "prisma generate",
    "db:setup:dev": "npm run db:push && npm run db:seed",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:repair": "tsx scripts/resolve-failed-migrations.ts",
    "db:migrate:deploy": "prisma migrate deploy",
    "predeploy:prod": "npm run db:migrate:deploy && npm run db:generate && npm run db:smoke && npm run emails:ensure-required",
    "maintenance:migrations:repair": "npm run db:migrate:repair",
    "postinstall": "npm run prisma:generate",
    "content:diagnose": "npx tsx scripts/diagnose-home-content.ts",
    "content:ensure:welcome": "npx tsx scripts/ensure-welcome-template.ts",
    "emails:ensure-required": "npx tsx scripts/ensure-required-emails.ts",
    "clerk:resync": "npx tsx scripts/resync-clerk-access.ts",
    "db:validate": "prisma validate",
    "vercel-build": "npm run db:migrate:repair && npm run db:migrate:deploy && npm run db:generate && next build",
    "content:fix:main-creator": "npx tsx scripts/fix-main-creator-content.ts",
    "env:validate": "tsx scripts/validate-env.ts",
    "env:validate:prod": "tsx scripts/validate-env.ts --mode=production",
    "quality:strict-escapes": "tsx scripts/check-strict-escapes.ts",
    "quality:hotspots": "tsx scripts/check-hotspots.ts",
    "quality:architecture-boundaries": "tsx scripts/check-architecture.ts",
    "quality": "npm run quality:architecture-boundaries && npm run typecheck && npm test -- --run",
    "e2e": "tsx scripts/validate-e2e-env.ts && playwright test",
    "e2e:list": "playwright test --list",
    "e2e:install": "playwright install chromium",
    "test:integration:postgres": "prisma migrate deploy && prisma generate && npm run db:smoke",
    "launch:diagnose": "tsx scripts/launch-diagnose.ts",
    "audit:high": "node scripts/audit-high.mjs"
  },
  "dependencies": {
