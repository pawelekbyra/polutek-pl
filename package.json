    "lucide-react": "^0.577.0",
    "next": "16.2.6",
    "perfect-freehand": "^1.2.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-easy-crop": "^6.0.2",
    "resend": "^6.9.4",
    "rough-notation": "^0.5.1",
    "roughjs": "^4.6.6",
    "sanitize-html": "^2.17.4",
    "shadcn": "^4.8.0",
    "stripe": "^20.4.1",
    "svix": "^1.89.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "^1.4.0",
    "tus-js-client": "^4.3.1",
    "typescript": "5.9.3",
    "vidstack": "^1.15.6",
    "wired-elements": "^3.0.0-rc.6",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "npx ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
