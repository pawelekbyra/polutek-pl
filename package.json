{
  "name": "polutek",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:verify": "npx ts-node scripts/verify_db.ts",
    "db:smoke": "tsx scripts/db-smoke.ts",
    "db:generate": "prisma generate",
    "prisma:generate": "prisma generate",
    "db:setup:dev": "npm run db:push && npm run db:seed",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:repair": "tsx scripts/resolve-failed-migrations.ts",
    "db:migrate:deploy": "prisma migrate deploy",
    "predeploy:prod": "npm run db:migrate:repair && npm run db:migrate:deploy && npm run db:generate && npm run db:smoke && npm run emails:ensure-required",
    "postinstall": "npm run prisma:generate",
    "content:diagnose": "npx tsx scripts/diagnose-home-content.ts",
    "content:ensure:welcome": "npx tsx scripts/ensure-welcome-template.ts",
    "emails:ensure-required": "npx tsx scripts/ensure-required-emails.ts",
    "clerk:resync": "npx tsx scripts/resync-clerk-access.ts",
    "db:validate": "prisma validate",
    "vercel-build": "npm run db:migrate:repair && npm run db:migrate:deploy && npm run db:generate && npm run db:smoke && next build",
    "content:fix:main-creator": "npx tsx scripts/fix-main-creator-content.ts",
    "env:validate": "tsx scripts/validate-env.ts",
    "env:validate:prod": "tsx scripts/validate-env.ts --mode=production",
    "quality:strict-escapes": "tsx scripts/check-strict-escapes.ts",
    "e2e": "tsx scripts/validate-e2e-env.ts && playwright test",
    "e2e:list": "playwright test --list",
    "e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "sanitize-html": "^2.17.4",
    "@base-ui/react": "^1.5.0",
    "@clerk/localizations": "^4.2.4",
    "@clerk/nextjs": "^5.7.5",
    "@prisma/client": "^6.4.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.94.5",
    "@vercel/blob": "^2.3.1",
    "@vidstack/react": "^1.12.13",
    "artplayer": "^5.4.0",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.577.0",
    "next": "^14.2.35",
    "postcss": "^8.5.6",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.9.4",
    "shadcn": "^4.8.0",
    "stripe": "^20.4.1",
    "svix": "^1.89.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.4.5",
    "vidstack": "^1.12.13",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "npx ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/ui": "^4.1.7",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "playwright": "^1.58.2",
    "prisma": "^6.4.1",
    "tsx": "^4.22.4",
    "vitest": "^4.1.7"
  }
}
