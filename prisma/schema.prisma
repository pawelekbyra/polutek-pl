generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String              @id // This is now the clerkUserId directly
  email            String              @unique
  username         String?
  name             String?
  isDeleted        Boolean             @default(false)
  role             SystemRole          @default(USER)
  language         String              @default("en")
  totalPaid        Float               @default(0) // Lifetime sum of all payments
  referralCode     String              @unique @default(cuid())
  referralPoints   Int                 @default(0)
  referralCount    Int                 @default(0)
  referredById     String?
  referredBy       User?               @relation("UserReferrals", fields: [referredById], references: [id])
  referrals        User[]              @relation("UserReferrals")
  stripeCustomerId String?             @unique
  imageUrl         String?
  isPatron         Boolean             @default(false)
  patronSince      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  creators         Creator[]
  comments         Comment[]
  commentLikes     CommentLike[]
  commentDislikes  CommentDislike[]
  videoLikes       VideoLike[]
  videoDislikes    VideoDislike[]
  transactions     Transaction[]
  subscriptions    Subscription[]

  @@index([email])
}

model Transaction {
  id               String   @id @default(uuid())
  userId           String
  creatorId        String?  // Made optional for now to not break existing data if any, but should be mandatory in logic
  amount           Float
  currency         String   @default("EUR")
  stripeSessionId  String   @unique
  status           String   @default("PENDING") // PENDING, COMPLETED, FAILED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  creator          Creator? @relation(fields: [creatorId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([creatorId])
  @@index([status])
}

model Creator {
  id               String    @id @default(uuid())
  userId           String
  slug             String    @unique
  name             String
  bio              String?
  bannerUrl        String?
  subscribersCount Int       @default(0)
  isApproved       Boolean   @default(false)
  stripeConnectId  String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id])
  videos           Video[]
  transactions     Transaction[]
  comments         Comment[]
  subscriptions    Subscription[]
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String
  creatorId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([userId, creatorId])
  @@index([userId])
  @@index([creatorId])
}

model Video {
  id            String    @id @default(uuid())
  creatorId     String
  title         String
  slug          String    @unique
  description   String?
  videoUrl      String
  thumbnailUrl  String
  duration      String?   // e.g. "12:45"
  tier          AccessTier @default(PUBLIC)
  views         Int       @default(0)
  likesCount    Int       @default(0)
  dislikesCount Int       @default(0)
  isMainFeatured Boolean  @default(false) // This video is the "One Hero Video" on homepage
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creator       Creator   @relation(fields: [creatorId], references: [id])
  comments      Comment[]
  videoLikes    VideoLike[]
  videoDislikes VideoDislike[]

  @@index([creatorId])
  @@index([slug])
}

model VideoLike {
  id        String   @id @default(uuid())
  userId    String
  videoId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, videoId])
  @@index([videoId])
  @@index([userId])
}

model VideoDislike {
  id        String   @id @default(uuid())
  userId    String
  videoId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, videoId])
  @@index([videoId])
  @@index([userId])
}

model Comment {
  id         String   @id @default(uuid())
  text       String
  imageUrl   String?
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  videoId    String
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  creatorId  String?  // Optional for now
  creator    Creator? @relation(fields: [creatorId], references: [id], onDelete: SetNull)

  // Self-relation for replies
  parentId   String?
  parent     Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentReplies")

  likes      CommentLike[]
  dislikes   CommentDislike[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([videoId])
  @@index([parentId])
  @@index([creatorId])
}

model CommentLike {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
  @@index([userId])
}

model CommentDislike {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
  @@index([userId])
}

enum AccessTier {
  PUBLIC    // Everyone
  LOGGED_IN // Minimum: Logged in (Clerk mail)
  PATRON    // Minimum: isPatron status granted
}

enum SystemRole {
  ADMIN
  USER
}

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String   @unique // e.g., "WELCOME"
  subjectPl String
  bodyPl    String   @db.Text
  subjectEn String
  bodyEn    String   @db.Text
  updatedAt DateTime @updatedAt
}
