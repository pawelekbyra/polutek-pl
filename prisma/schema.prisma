generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id                            String     @id // This is now the clerkUserId directly
  email                         String     @unique
  username                      String?
  name                          String?
  isDeleted                     Boolean    @default(false)
  role                          SystemRole @default(USER)
  language                      String     @default("en")
  // Legacy historical mixed-currency aggregate kept only for old rows.
  // Do not use for patron eligibility, financial reporting, access decisions, or payment sync.
  // Use UserPaymentTotal per currency or normalized totals instead.
  legacyTotalPaidMinor_DoNotUse Int        @default(0) @map("totalPaidMinor")
  stripeCustomerId              String?    @unique
  imageUrl                      String?
  canCreateChannel              Boolean    @default(false)
  createdAt                     DateTime   @default(now())
  updatedAt                     DateTime   @updatedAt

  creators         Creator[]
  comments         Comment[]
  commentLikes     CommentLike[]
  commentDislikes  CommentDislike[]
  commentReactions CommentReaction[]
  commentReports   CommentReport[]
  videoLikes       VideoLike[]
  videoDislikes    VideoDislike[]
  payments         Payment[]
  paymentTotals    UserPaymentTotal[]
  patronGrants     PatronGrant[]
  subscriptions    Subscription[]
  notifications    Notification[]

  @@index([email])
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
  CHARGEBACK_LOST
}

model Payment {
  id                  String        @id @default(uuid())
  userId              String
  creatorId           String?
  stripeIntentId      String?       @unique
  stripeSessionId     String?       @unique
  requestId           String?
  amountMinor         Int
  refundedAmountMinor Int           @default(0)
  currency            String
  status              PaymentStatus @default(PENDING)
  metadata            Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  creator Creator? @relation(fields: [creatorId], references: [id])

  @@unique([userId, requestId])
  @@index([userId, status])
  @@index([userId])
  @@index([creatorId])
  @@index([status])
  @@index([createdAt])
}

enum WebhookEventStatus {
  PROCESSING
  PROCESSED
  FAILED
}

model StripeEvent {
  id          String             @id
  type        String
  status      WebhookEventStatus @default(PROCESSING)
  payload     Json?
  error       String?
  processedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model ClerkEvent {
  id          String             @id
  type        String
  status      WebhookEventStatus @default(PROCESSING)
  payload     Json?
  error       String?
  processedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

enum PatronGrantSource {
  STRIPE_TIP
  PAYMENT
  REFERRAL
  ADMIN
  MIGRATION
  LEGACY
}

model PatronGrant {
  id          String            @id @default(uuid())
  userId      String
  source      PatronGrantSource
  paymentId   String?           @unique
  grantedById String?
  reason      String?
  createdAt   DateTime          @default(now())
  revokedAt   DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt])
  @@index([userId])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  targetType  String?
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model Creator {
  id                      String         @id @default(uuid())
  userId                  String
  slug                    String         @unique
  name                    String
  bio                     String?
  bannerUrl               String?
  defaultThumbnailUrl     String?
  subscribersCount        Int            @default(0)
  displaySubscribersCount Int?
  isApproved              Boolean        @default(false)
  isPrimary               Boolean        @default(false)
  stripeConnectId         String?        @unique
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  user                    User           @relation(fields: [userId], references: [id])
  videos                  Video[]
  payments                Payment[]
  comments                Comment[]
  subscriptions           Subscription[]
}

model Subscription {
  /// LEGACY: historical channel-follow/subscription records only.
  /// Do not use this model for premium/patron content access; active PatronGrant rows are the only access source of truth.
  id        String   @id @default(uuid())
  userId    String
  creatorId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([userId, creatorId])
  @@index([userId])
  @@index([creatorId])
}

enum NotificationKind {
  WELCOME
  SYSTEM
  COMMENT
  SUPPORT
  PATRON
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  kind      NotificationKind
  titlePl   String
  titleEn   String
  bodyPl    String           @db.Text
  bodyEn    String           @db.Text
  href      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, read])
}

model Video {
  id                                String      @id @default(uuid())
  creatorId                         String
  title                             String
  titleEn                           String?
  slug                              String      @unique
  description                       String?
  descriptionEn                     String?
  videoUrl                          String? // Legacy field
  thumbnailUrl                      String
  subtitleUrlPl                     String?
  subtitleUrlEn                     String?
  duration                          String? // e.g. "12:45"
  tier                              AccessTier  @default(PUBLIC)
  views                             Int         @default(0)
  likesCount                        Int         @default(0)
  dislikesCount                     Int         @default(0)
  isMainFeatured                    Boolean     @default(false) // This video is the "One Hero Video" on homepage
  showInSidebar                     Boolean     @default(true)
  sidebarOrder                      Int         @default(0)
  status                            VideoStatus @default(DRAFT)
  publishedAt                       DateTime?
  publishAfterAssetReady            Boolean     @default(false)
  publishAfterAssetReadyProvider    String?
  publishAfterAssetReadyRequestedAt DateTime?
  publishAfterAssetReadyCompletedAt DateTime?
  publishAfterAssetReadyError       String?
  activeOriginalId                  String?     @unique
  activePlaybackRouteId             String?     @unique
  createdAt                         DateTime    @default(now())
  updatedAt                         DateTime    @updatedAt

  creator             Creator                 @relation(fields: [creatorId], references: [id])
  comments            Comment[]
  videoLikes          VideoLike[]
  videoDislikes       VideoDislike[]
  assets              VideoAsset[]
  distributionPlans   VideoDistributionPlan[] @relation("VideoDistributionPlans")
  originals           VideoOriginal[]         @relation("VideoOriginals")
  playbackRoutes      VideoPlaybackRoute[]    @relation("VideoPlaybackRoutes")
  activeOriginal      VideoOriginal?          @relation("ActiveVideoOriginal", fields: [activeOriginalId], references: [id], onDelete: SetNull)
  activePlaybackRoute VideoPlaybackRoute?     @relation("ActivePlaybackRoute", fields: [activePlaybackRouteId], references: [id], onDelete: SetNull)
  videoViews          VideoView[]
  playbackSessions    VideoPlaybackSession[]
  playbackEvents      VideoPlaybackEvent[]

  @@index([status, publishedAt])
  @@index([status, createdAt])
  @@index([creatorId, status])
  @@index([publishAfterAssetReady])
  @@index([activeOriginalId])
  @@index([activePlaybackRouteId])
  @@index([creatorId])
  @@index([slug])
}

enum StorageProvider {
  /// LEGACY/MIGRATION ONLY: object storage asset, not the active private patron playback target.
  R2
  /// LEGACY/MIGRATION ONLY: object storage asset, not the active private patron playback target.
  S3
  /// LEGACY/MIGRATION ONLY: object storage asset, not the active private patron playback target.
  VERCEL_BLOB
  /// Owner-approved first private video provider for new video assets.
  CLOUDFLARE_STREAM
  /// Full VOD provider with signed HLS playback. Requires MUX_TOKEN_ID, MUX_TOKEN_SECRET, MUX_SIGNING_KEY_ID, MUX_SIGNING_PRIVATE_KEY.
  MUX
  /// YouTube embed source. Admin can enable for any tier.
  YOUTUBE
  /// Vimeo embed source. Admin can enable for any tier.
  VIMEO
}

enum VideoOriginalStatus {
  PROVISIONING
  UPLOADING
  UPLOADED
  VERIFYING
  READY
  FAILED
  SUPERSEDED
  ABANDONED
}

enum VideoDistributionMode {
  SINGLE_PROVIDER
  MULTI_PROVIDER
  AUTO
  MANUAL
}

enum VideoPlaybackSelectionPolicy {
  MANUAL
  FIRST_READY
  PREFER_SELECTED
  BEST_HEALTH
  LOWEST_COST
}

enum VideoAutopublishPolicy {
  NEVER
  WHEN_ANY_TARGET_READY
  WHEN_ALL_REQUIRED_TARGETS_READY
  WHEN_ACTIVE_ROUTE_READY
}

enum VideoDistributionTargetStatus {
  REQUESTED
  QUEUED
  STARTING
  WAITING_PROVIDER
  READY
  FAILED
  DISABLED
  CANCELLED
}

enum VideoDistributionTargetRole {
  PRIMARY
  BACKUP
  CANDIDATE
}

enum VideoProviderJobType {
  IMPORT_FROM_ORIGINAL
  DIRECT_UPLOAD
  ATTACH_EXISTING
  SYNC_STATUS
  DELETE_PROVIDER_ASSET
}

enum VideoProviderJobStatus {
  QUEUED
  RUNNING
  WAITING_PROVIDER
  READY
  FAILED
  CANCELLED
  ABANDONED
}

enum VideoPlaybackRouteStatus {
  ACTIVE
  PREVIOUS
  DISABLED
  FAILED
}

enum VideoPlaybackRouteActivatedBy {
  ADMIN
  POLICY
  FALLBACK
  MIGRATION
  RECONCILER
}

enum VideoProviderWebhookStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum VideoAssetProcessingState {
  PENDING
  UPLOADING
  PROCESSING
  READY
  FAILED
}

model VideoAsset {
  id                     String                    @id @default(uuid())
  videoId                String
  distributionTargetId   String?
  provider               StorageProvider
  objectKey              String
  bucket                 String?
  providerAssetId        String?
  providerPlaybackId     String?
  externalVideoId        String?
  externalUrl            String?
  processingState        VideoAssetProcessingState @default(READY)
  isPrimary              Boolean                   @default(true)
  pendingPrimaryIntent   Boolean                   @default(false)
  muxUploadId            String?
  failureReason          String?
  providerSyncedAt       DateTime?
  processingStartedAt    DateTime?
  processingEndedAt      DateTime?
  mimeType               String?
  sizeBytes              Int?
  // Mirror metadata
  fallbackPriority       Int                       @default(100)
  mirrorSourceOriginalId String?
  mirrorRequestedAt      DateTime?
  mirrorCompletedAt      DateTime?
  mirrorFailureReason    String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  video              Video                    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  distributionTarget VideoDistributionTarget? @relation(fields: [distributionTargetId], references: [id], onDelete: SetNull)
  providerJobs       VideoProviderJob[]
  playbackRoutes     VideoPlaybackRoute[]

  @@index([videoId])
  @@index([distributionTargetId])
  @@index([videoId, isPrimary])
  @@index([provider])
  @@index([processingState])
  @@index([provider, providerAssetId])
}

model VideoOriginal {
  id                String              @id @default(uuid())
  videoId           String
  storageProvider   StorageProvider     @default(R2)
  bucket            String
  objectKey         String
  originalFileName  String?
  mimeType          String?
  sizeBytes         BigInt?
  checksumSha256    String?
  status            VideoOriginalStatus @default(UPLOADING)
  failureReason     String?
  version           Int                 @default(1)
  uploadStartedAt   DateTime?
  uploadCompletedAt DateTime?
  verifiedAt        DateTime?
  supersededAt      DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  video             Video                   @relation("VideoOriginals", fields: [videoId], references: [id], onDelete: Cascade)
  activeForVideo    Video?                  @relation("ActiveVideoOriginal")
  distributionPlans VideoDistributionPlan[]
  providerJobs      VideoProviderJob[]

  @@unique([videoId, version])
  @@index([videoId])
  @@index([videoId, version])
  @@index([status])
}

model VideoDistributionPlan {
  id                 String                       @id @default(uuid())
  videoId            String
  originalId         String?
  mode               VideoDistributionMode        @default(SINGLE_PROVIDER)
  selectionPolicy    VideoPlaybackSelectionPolicy @default(PREFER_SELECTED)
  autopublishPolicy  VideoAutopublishPolicy       @default(NEVER)
  preferredProvider  StorageProvider?
  isActive           Boolean                      @default(true)
  publishRequestedAt DateTime?
  publishCompletedAt DateTime?
  publishError       String?
  createdByAdminId   String?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  video          Video                     @relation("VideoDistributionPlans", fields: [videoId], references: [id], onDelete: Cascade)
  original       VideoOriginal?            @relation(fields: [originalId], references: [id], onDelete: SetNull)
  targets        VideoDistributionTarget[]
  providerJobs   VideoProviderJob[]
  playbackRoutes VideoPlaybackRoute[]

  @@index([videoId, isActive])
  @@index([originalId])
  @@index([preferredProvider])
}

model VideoDistributionTarget {
  id             String                        @id @default(uuid())
  planId         String
  videoId        String
  provider       StorageProvider
  role           VideoDistributionTargetRole   @default(CANDIDATE)
  required       Boolean                       @default(true)
  status         VideoDistributionTargetStatus @default(REQUESTED)
  desiredPrimary Boolean                       @default(false)
  lastError      String?
  lastStatusAt   DateTime?
  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt

  plan           VideoDistributionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  providerJobs   VideoProviderJob[]
  providerAssets VideoAsset[]

  @@unique([planId, provider])
  @@index([planId])
  @@index([videoId])
  @@index([provider])
  @@index([status])
}

model VideoProviderJob {
  id                 String                 @id @default(uuid())
  videoId            String
  planId             String?
  targetId           String?
  originalId         String?
  assetId            String?
  provider           StorageProvider
  type               VideoProviderJobType
  status             VideoProviderJobStatus @default(QUEUED)
  attemptCount       Int                    @default(0)
  maxAttempts        Int                    @default(3)
  idempotencyKey     String?
  providerAssetId    String?
  providerPlaybackId String?
  providerUploadId   String?
  lastError          String?
  lastErrorCode      String?
  nextAttemptAt      DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  lastReconciledAt   DateTime?
  lastWebhookAt      DateTime?
  metadata           Json?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  plan     VideoDistributionPlan?   @relation(fields: [planId], references: [id], onDelete: SetNull)
  target   VideoDistributionTarget? @relation(fields: [targetId], references: [id], onDelete: SetNull)
  original VideoOriginal?           @relation(fields: [originalId], references: [id], onDelete: SetNull)
  asset    VideoAsset?              @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@unique([idempotencyKey])
  @@index([videoId])
  @@index([planId])
  @@index([targetId])
  @@index([originalId])
  @@index([assetId])
  @@index([provider, providerAssetId])
  @@index([providerUploadId])
  @@index([status, nextAttemptAt])
}

model VideoPlaybackRoute {
  id               String                        @id @default(uuid())
  videoId          String
  planId           String?
  assetId          String
  provider         StorageProvider
  status           VideoPlaybackRouteStatus      @default(ACTIVE)
  activatedBy      VideoPlaybackRouteActivatedBy @default(POLICY)
  activationReason String?
  activatedAt      DateTime                      @default(now())
  deactivatedAt    DateTime?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt

  video          Video                  @relation("VideoPlaybackRoutes", fields: [videoId], references: [id], onDelete: Cascade)
  activeForVideo Video?                 @relation("ActivePlaybackRoute")
  plan           VideoDistributionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  asset          VideoAsset             @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([videoId, status])
  @@index([assetId])
  @@index([provider])
}

model VideoProviderWebhookEvent {
  id               String                     @id @default(uuid())
  provider         StorageProvider
  externalEventId  String?
  eventType        String
  providerAssetId  String?
  providerUploadId String?
  status           VideoProviderWebhookStatus @default(RECEIVED)
  receivedAt       DateTime                   @default(now())
  processedAt      DateTime?
  error            String?
  payload          Json

  @@unique([provider, externalEventId])
  @@index([provider])
  @@index([eventType])
  @@index([providerAssetId])
  @@index([providerUploadId])
  @@index([status])
}

model VideoLike {
  id        String   @id @default(uuid())
  userId    String
  videoId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, videoId])
  @@index([videoId])
  @@index([userId])
}

model VideoDislike {
  id        String   @id @default(uuid())
  userId    String
  videoId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, videoId])
  @@index([videoId])
  @@index([userId])
}

model Comment {
  id       String  @id @default(uuid())
  text     String
  imageUrl String?
  authorId String
  author   User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  creatorId String? // Optional for now
  creator   Creator? @relation(fields: [creatorId], references: [id], onDelete: SetNull)

  // Self-relation for replies
  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  status       CommentStatus @default(VISIBLE)
  likesCount   Int           @default(0)
  repliesCount Int           @default(0)
  reportsCount Int           @default(0)
  score        Int           @default(0)
  isHearted    Boolean       @default(false)

  pinnedAt   DateTime?
  pinnedById String?

  editedAt      DateTime?
  deletedAt     DateTime?
  deletedById   String?
  deletedReason CommentDeletedReason?

  moderatedAt   DateTime?
  moderatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  likes     CommentLike[]
  dislikes  CommentDislike[]
  reactions CommentReaction[]
  reports   CommentReport[]

  @@index([videoId, pinnedAt, createdAt])
  @@index([videoId, createdAt])
  @@index([parentId, createdAt])
  @@index([videoId])
  @@index([parentId])
  @@index([creatorId])
  @@index([status])
}

model CommentReaction {
  id        String              @id @default(uuid())
  userId    String
  commentId String
  type      CommentReactionType @default(LIKE)
  createdAt DateTime            @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId, type])
  @@index([userId])
}

model CommentReport {
  id           String              @id @default(uuid())
  commentId    String
  reporterId   String
  reason       CommentReportReason
  note         String?
  status       CommentReportStatus @default(PENDING)
  createdAt    DateTime            @default(now())
  resolvedAt   DateTime?
  resolvedById String?

  comment  Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporter User    @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([commentId, reporterId])
  @@index([status, createdAt])
  @@index([commentId])
  @@index([reporterId])
}

model CommentLike {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
  @@index([userId])
}

model CommentDislike {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
  @@index([userId])
}

enum AccessTier {
  PUBLIC // Everyone
  LOGGED_IN // Minimum: Logged in (Clerk mail)
  PATRON // Minimum: isPatron status granted
}

enum VideoStatus {
  DRAFT
  PUBLISHED
  UNLISTED
  ARCHIVED
}

model VideoView {
  id        String   @id @default(uuid())
  videoId   String
  userId    String?
  ipHash    String?
  createdAt DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([userId])
  @@index([ipHash])
}

enum SystemRole {
  ADMIN
  USER
}

enum CommentStatus {
  VISIBLE
  HELD_FOR_REVIEW
  HIDDEN
  DELETED
}

enum CommentDeletedReason {
  AUTHOR_DELETED
  MODERATOR_DELETED
  SPAM
  ABUSE
  OTHER
}

enum CommentReactionType {
  LIKE
  DISLIKE
}

enum CommentReportReason {
  SPAM
  HARASSMENT
  HATE
  NSFW
  SPOILER
  OTHER
}

enum CommentReportStatus {
  PENDING
  DISMISSED
  ACTION_TAKEN
}

model UserPaymentTotal {
  id          String @id @default(uuid())
  userId      String
  currency    String
  amountMinor Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
}

model PaymentCurrencySetting {
  currency             String   @id
  // Technical checkout floor — the smallest tip the checkout/Stripe will accept at all.
  minAmountMinor       Int
  // Patron-eligibility gate price. A tip at or above this grants lifetime patron access,
  // and it is the fixed amount shown to non-patrons in the support box. Null → falls back
  // to the PATRON_MIN_TIP_* env (matching currency) or, failing that, to minAmountMinor.
  patronThresholdMinor Int?
  // Minimum for the free-amount patron support box (existing patrons). Independent of the
  // patron threshold above. Null → falls back to minAmountMinor (the checkout floor).
  patronBoxMinMinor    Int?
  updatedAt            DateTime @updatedAt

  @@index([updatedAt])
}

enum EmailTemplateCategory {
  SYSTEM
  WELCOME
  PAYMENT
  PATRON
  BROADCAST
  MANUAL
  OTHER
}

enum EmailSuppressionReason {
  BOUNCE
  COMPLAINT
}

model EmailSuppression {
  id              String                 @id @default(uuid())
  email           String                 @unique
  reason          EmailSuppressionReason
  active          Boolean                @default(true)
  firstSeenAt     DateTime               @default(now())
  lastSeenAt      DateTime               @updatedAt
  providerEmailId String?
  source          String                 @default("RESEND_WEBHOOK")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([active])
  @@index([reason])
}

model EmailTemplate {
  id          String                @id @default(uuid())
  slug        String                @unique // e.g., "welcome-email"
  name        String?
  description String?
  category    EmailTemplateCategory @default(OTHER)
  isSystem    Boolean               @default(false)
  isActive    Boolean               @default(true)
  subject     String
  html        String                @db.Text
  subjectEn   String?
  htmlEn      String?               @db.Text
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  broadcasts BroadcastEmail[]
}

enum BroadcastStatus {
  DRAFT
  READY
  SENDING
  SENT
  PARTIAL_FAILED
  FAILED
  CANCELLED
}

enum BroadcastRecipientGroup {
  ALL
  SUBSCRIBERS
  PATRONS
  MANUAL
}

model BroadcastEmail {
  id             String                  @id @default(uuid())
  templateId     String?
  createdById    String?
  subjectPl      String
  htmlPl         String                  @db.Text
  subjectEn      String
  htmlEn         String                  @db.Text
  recipientGroup BroadcastRecipientGroup @default(SUBSCRIBERS)
  recipientCount Int                     @default(0)
  sentCount      Int                     @default(0)
  errorCount     Int                     @default(0)
  status         BroadcastStatus         @default(DRAFT)
  sentAt         DateTime?
  scheduledAt    DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  template   EmailTemplate?            @relation(fields: [templateId], references: [id])
  recipients BroadcastEmailRecipient[]

  @@index([status])
  @@index([createdAt])
}

enum BroadcastRecipientStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  FAILED
  SKIPPED
  UNSUBSCRIBED
}

model BroadcastEmailRecipient {
  id               String                   @id @default(uuid())
  broadcastEmailId String
  userId           String?
  email            String
  language         String                   @default("pl")
  status           BroadcastRecipientStatus @default(PENDING)
  resendEmailId    String?
  error            String?
  sentAt           DateTime?
  deliveredAt      DateTime?
  openedAt         DateTime?
  clickedAt        DateTime?
  bouncedAt        DateTime?
  complainedAt     DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  broadcast BroadcastEmail @relation(fields: [broadcastEmailId], references: [id], onDelete: Cascade)

  @@index([broadcastEmailId])
  @@index([email])
  @@index([status])
}

model EmailPreference {
  id              String    @id @default(uuid())
  userId          String?   @unique
  email           String    @unique
  marketingEmails Boolean   @default(true)
  systemEmails    Boolean   @default(true)
  unsubscribedAt  DateTime?
  resendContactId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([email])
}

enum InboundEmailStatus {
  NEW
  READ
  ARCHIVED
  RESOLVED
}

model InboundEmail {
  id               String             @id @default(uuid())
  fromEmail        String
  fromName         String?
  toEmail          String
  subject          String?
  text             String?            @db.Text
  html             String?            @db.Text
  resendId         String             @unique
  status           InboundEmailStatus @default(NEW)
  userId           String?
  broadcastEmailId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([fromEmail])
  @@index([status])
}

model EmailEvent {
  id               String             @id @default(uuid())
  type             String
  status           WebhookEventStatus @default(PROCESSED)
  providerEventId  String?            @unique
  resendEmailId    String?
  broadcastEmailId String?
  recipientId      String?
  userId           String?
  email            String?
  payload          Json
  error            String?
  processedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([resendEmailId])
  @@index([broadcastEmailId])
  @@index([email])
}

model VideoPlaybackSession {
  id              String     @id @default(uuid())
  videoId         String
  userId          String?
  ipHash          String?
  userAgentHash   String?
  sourceKind      String?
  provider        String?
  accessTier      AccessTier
  startedAt       DateTime   @default(now())
  firstPlayAt     DateTime?
  lastHeartbeatAt DateTime?  @default(now())
  endedAt         DateTime?
  totalWatchMs    Int        @default(0)
  maxProgressMs   Int        @default(0)
  durationMs      Int?
  countedAsView   Boolean    @default(false)
  isAdminPreview  Boolean    @default(false)
  errorCode       String?
  errorMessage    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  video  Video                @relation(fields: [videoId], references: [id], onDelete: Cascade)
  events VideoPlaybackEvent[]

  @@index([videoId])
  @@index([userId])
  @@index([countedAsView])
  @@index([startedAt])
  @@index([isAdminPreview])
}

model VideoPlaybackEvent {
  id           String   @id @default(uuid())
  sessionId    String?
  videoId      String
  userId       String?
  type         String
  positionMs   Int?
  durationMs   Int?
  bufferedMs   Int?
  volume       Float?
  muted        Boolean?
  fullscreen   Boolean?
  errorCode    String?
  errorMessage String?
  provider     String?
  sourceKind   String?
  metadata     Json?
  createdAt    DateTime @default(now())

  session VideoPlaybackSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  video   Video                 @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([videoId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}
