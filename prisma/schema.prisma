generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id               String              @id // This is now the clerkUserId directly
  email            String              @unique
  username         String?
  name             String?
  isDeleted        Boolean             @default(false)
  role             SystemRole          @default(USER)
  language         String              @default("en")
  totalPaidMinor   Int                 @default(0) // Lifetime sum of all payments in minor units
  referralCode     String              @unique @default(cuid())
  referralPoints   Int                 @default(0)
  referralCount    Int                 @default(0)
  referredById     String?
  referredBy       User?               @relation("UserReferrals", fields: [referredById], references: [id])
  referrals        User[]              @relation("UserReferrals")
  stripeCustomerId String?             @unique
  imageUrl         String?
  isPatron         Boolean             @default(false)
  patronSince      DateTime?
  canCreateChannel Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  creators         Creator[]
  comments         Comment[]
  commentLikes     CommentLike[]
  commentDislikes  CommentDislike[]
  videoLikes       VideoLike[]
  videoDislikes    VideoDislike[]
  payments         Payment[]
  paymentTotals    UserPaymentTotal[]
  patronGrants     PatronGrant[]
  referralsSent    Referral[]          @relation("ReferralReferrer")
  referralReceived Referral?           @relation("ReferralReferred")
  subscriptions    Subscription[]

  @@index([email])
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
}

model Payment {
  id              String        @id @default(uuid())
  userId          String
  creatorId       String?
  stripeIntentId  String?       @unique
  stripeSessionId String?       @unique
  amountMinor     Int
  currency        String
  status          PaymentStatus @default(PENDING)
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  creator         Creator?      @relation(fields: [creatorId], references: [id])

  @@index([userId])
  @@index([creatorId])
  @@index([status])
  @@index([createdAt])
}

enum StripeEventStatus {
  PROCESSING
  PROCESSED
  FAILED
}

model StripeEvent {
  id          String            @id
  type        String
  status      StripeEventStatus @default(PROCESSING)
  payload     Json?
  error       String?
  processedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum PatronGrantSource {
  PAYMENT
  REFERRAL
  ADMIN
  LEGACY
}

model PatronGrant {
  id            String            @id @default(uuid())
  userId        String
  source        PatronGrantSource
  paymentId     String?
  referralId    String?
  grantedById   String?
  reason        String?
  createdAt     DateTime          @default(now())
  revokedAt     DateTime?

  user          User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  targetType  String?
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}

model Creator {
  id               String    @id @default(uuid())
  userId           String
  slug             String    @unique
  name             String
  bio              String?
  bannerUrl        String?
  subscribersCount Int       @default(0)
  isApproved       Boolean   @default(false)
  isPrimary        Boolean   @default(false)
  stripeConnectId  String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id])
  videos           Video[]
  payments         Payment[]
  comments         Comment[]
  subscriptions    Subscription[]
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String
  creatorId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([userId, creatorId])
  @@index([userId])
  @@index([creatorId])
}

model Video {
  id            String    @id @default(uuid())
  creatorId     String
  title         String
  slug          String    @unique
  description   String?
  videoUrl      String    // Legacy field
  thumbnailUrl  String
  duration      String?   // e.g. "12:45"
  tier          AccessTier @default(PUBLIC)
  views         Int       @default(0)
  likesCount    Int       @default(0)
  dislikesCount Int       @default(0)
  isMainFeatured Boolean  @default(false) // This video is the "One Hero Video" on homepage
  status        VideoStatus @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creator       Creator   @relation(fields: [creatorId], references: [id])
  comments      Comment[]
  videoLikes    VideoLike[]
  videoDislikes VideoDislike[]
  asset         VideoAsset?
  videoViews    VideoView[]

  @@index([creatorId])
  @@index([slug])
}

enum StorageProvider {
  R2
  S3
  VERCEL_BLOB
}

model VideoAsset {
  id          String          @id @default(uuid())
  videoId     String          @unique
  provider    StorageProvider
  objectKey   String
  bucket      String?
  mimeType    String?
  sizeBytes   Int?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  video       Video           @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([provider])
}

enum ReferralStatus {
  PENDING
  CLAIMED
  REJECTED
  CANCELED
}

model Referral {
  id          String         @id @default(uuid())
  referrerId  String
  referredId  String         @unique
  status      ReferralStatus @default(PENDING)
  source      String?
  claimedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  referrer   User @relation("ReferralReferrer", fields: [referrerId], references: [id])
  referred   User @relation("ReferralReferred", fields: [referredId], references: [id])

  @@unique([referrerId, referredId])
  @@index([referrerId])
  @@index([status])
}

model VideoLike {
  id        String   @id @default(uuid())
  userId    String
  videoId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, videoId])
  @@index([videoId])
  @@index([userId])
}

model VideoDislike {
  id        String   @id @default(uuid())
  userId    String
  videoId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, videoId])
  @@index([videoId])
  @@index([userId])
}

model Comment {
  id         String   @id @default(uuid())
  text       String
  imageUrl   String?
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  videoId    String
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  creatorId  String?  // Optional for now
  creator    Creator? @relation(fields: [creatorId], references: [id], onDelete: SetNull)

  // Self-relation for replies
  parentId   String?
  parent     Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentReplies")

  likes      CommentLike[]
  dislikes   CommentDislike[]

  deletedAt  DateTime?
  deletedById String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([videoId])
  @@index([parentId])
  @@index([creatorId])
}

model CommentLike {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
  @@index([userId])
}

model CommentDislike {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
  @@index([userId])
}

enum AccessTier {
  PUBLIC    // Everyone
  LOGGED_IN // Minimum: Logged in (Clerk mail)
  PATRON    // Minimum: isPatron status granted
}

enum VideoStatus {
  DRAFT
  PUBLISHED
  UNLISTED
  ARCHIVED
}

model VideoView {
  id        String   @id @default(uuid())
  videoId   String
  userId    String?
  ipHash    String?
  createdAt DateTime @default(now())

  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([userId])
  @@index([ipHash])
}

enum SystemRole {
  ADMIN
  USER
}

model UserPaymentTotal {
  id          String @id @default(uuid())
  userId      String
  currency    String
  amountMinor Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
}

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String   @unique // e.g., "WELCOME"
  subjectPl String
  bodyPl    String   @db.Text
  subjectEn String
  bodyEn    String   @db.Text
  updatedAt DateTime @updatedAt
}
