# Clerk Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_publishable_key
CLERK_SECRET_KEY=your_secret_key
CLERK_WEBHOOK_SECRET=whsec_clerk_...

# Vercel Blob
BLOB_READ_WRITE_TOKEN=your_blob_token

# Database (Neon)
DATABASE_URL="postgresql://user:pass@ep-host.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-host.aws.neon.tech/neondb?sslmode=require"
PGHOST=ep-host.aws.neon.tech
PGUSER=user
PGDATABASE=neondb
PGPASSWORD=pass

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email
RESEND_API_KEY=re_...
EMAIL_FROM="Paweł Perfect <no-reply@polutek.pl>"

# App Config
APP_ENV=development
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=pawel.perfect@gmail.com


# Reserved for future multi-creator features
ENABLE_MULTI_CREATOR=false

# Demo content fallback. Enable for first run / demo. Opt-in only.
ENABLE_DEMO_FALLBACKS=false

# Security
HEALTHCHECK_TOKEN=your_secure_token

# Rate Limiting (Upstash Redis / Vercel KV)
# Required in production. Memory fallback is allowed only in development/test.
# Preferred explicit Upstash names:
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...
# Vercel KV fallback names are also supported for the writable REST credentials.
# Do not use KV_REST_API_READ_ONLY_TOKEN for rate limiting; counters must be writable.
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...

# Media Bucket / CDN host allowlist for /api/media and comment image attachments.
# Use exact controlled hosts only (for example a specific bucket host or CDN CNAME).
# Do not put broad provider domains such as r2.dev, r2.cloudflarestorage.com, or vercel-storage.com. HTTPS is required.
MEDIA_BUCKET_HOST=your-bucket.r2.dev
NEXT_PUBLIC_R2_PUBLIC_HOST=cdn.yourdomain.com
NEXT_PUBLIC_BLOB_PUBLIC_HOST=your-project.public.blob.vercel-storage.com
ALLOWED_MEDIA_HOSTS=cdn.yourdomain.com,your-bucket.r2.dev
