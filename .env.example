# Clerk Keys
# Required in every runtime mode; the app fails fast if this is missing.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_publishable_key
CLERK_SECRET_KEY=your_secret_key
CLERK_WEBHOOK_SECRET=whsec_clerk_...

# Vercel Blob
BLOB_READ_WRITE_TOKEN=your_blob_token

# Database (Neon)
DATABASE_URL="postgresql://user:pass@ep-host.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-host.aws.neon.tech/neondb?sslmode=require"
PGHOST=ep-host.aws.neon.tech
PGUSER=user
PGDATABASE=neondb
PGPASSWORD=pass

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email
RESEND_API_KEY=re_...
EMAIL_FROM="Polutek.pl <no-reply@polutek.pl>"

# App Config
APP_ENV=development
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional bootstrap/recovery email for seed/repair scripts only; not runtime admin access.
ADMIN_EMAIL=your-admin-email@example.com
# Runtime admin access allowlist. Required in production.
ADMIN_CLERK_USER_IDS=user_...
DISPLAY_EUR_TO_PLN_RATE=4.3
DISPLAY_USD_TO_PLN_RATE=4.0

# Patronage
PATRON_MIN_TIP_AMOUNT=500
PATRON_MIN_TIP_CURRENCY=EUR
REFERRAL_PATRON_THRESHOLD=5

# App mode
# [REMOVED] Polutek is now strict single-channel. Multi-creator mode is removed from runtime.

# Configured main channel slug. Required.
MAIN_CREATOR_SLUG=your-creator-slug
# Optional display name used by local content repair scripts when creating the configured creator.
MAIN_CREATOR_NAME=your-creator-display-name

# Demo content fallback. Enable only for local/dev/test first-run demos.
# Production code ignores this flag even if it is set to true; real production content must come from the database.
ENABLE_DEMO_FALLBACKS=false

# Security
HEALTHCHECK_TOKEN=your_secure_token
EMAIL_UNSUBSCRIBE_SIGNING_SECRET=replace-with-at-least-32-random-characters

# Rate Limiting (Upstash Redis / Vercel KV)
# Required in production. Memory fallback is allowed only in development/test.
# Preferred explicit Upstash names:
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...
# Vercel KV fallback names are also supported for the writable REST credentials.
# Do not use KV_REST_API_READ_ONLY_TOKEN for rate limiting; counters must be writable.
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...

# Media Bucket / CDN host allowlist for /api/media and admin video URLs.
# Use exact controlled hosts only (for example a specific bucket host or CDN CNAME).
# Do not put broad provider domains such as r2.dev, r2.cloudflarestorage.com, or vercel-storage.com. HTTPS is required.
MEDIA_BUCKET_HOST=your-bucket.r2.dev
NEXT_PUBLIC_R2_PUBLIC_HOST=cdn.yourdomain.com
NEXT_PUBLIC_BLOB_PUBLIC_HOST=your-project.public.blob.vercel-storage.com
ALLOWED_MEDIA_HOSTS=cdn.yourdomain.com,your-bucket.r2.dev

# Dedicated image allowlists. Keep these separate unless comments/avatars really share the same controlled storage.
ALLOWED_THUMBNAIL_HOSTS=i.ytimg.com,img.clerk.com,thumbs.yourdomain.com
ALLOWED_COMMENT_IMAGE_HOSTS=comments.yourdomain.com
ALLOWED_AVATAR_HOSTS=avatars.yourdomain.com

# Cloudflare Stream
# CLOUDFLARE_ACCOUNT_ID and CLOUDFLARE_API_TOKEN are required for Cloudflare Stream uploads.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_WEBHOOK_SECRET=
