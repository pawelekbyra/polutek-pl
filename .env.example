# Clerk Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_publishable_key
CLERK_SECRET_KEY=your_secret_key
CLERK_WEBHOOK_SECRET=whsec_clerk_...

# Vercel Blob
BLOB_READ_WRITE_TOKEN=your_blob_token

# Database (Neon)
# Recommended for most uses (pooled)
DATABASE_URL="postgresql://[user]:[password]@[host]-pooler.[region].aws.neon.tech/[db_name]?sslmode=require"

# For migrations and direct access (unpooled)
DATABASE_URL_UNPOOLED="postgresql://[user]:[password]@[host].[region].aws.neon.tech/[db_name]?sslmode=require"

# Parameters for constructing your own connection string
PGHOST="[host]-pooler.[region].aws.neon.tech"
PGHOST_UNPOOLED="[host].[region].aws.neon.tech"
PGUSER="[user]"
PGDATABASE="[db_name]"
PGPASSWORD="[password]"

# Parameters for Vercel Postgres Templates
POSTGRES_URL="postgresql://[user]:[password]@[host]-pooler.[region].aws.neon.tech/[db_name]?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://[user]:[password]@[host].[region].aws.neon.tech/[db_name]?sslmode=require"
POSTGRES_USER="[user]"
POSTGRES_HOST="[host]-pooler.[region].aws.neon.tech"
POSTGRES_PASSWORD="[password]"
POSTGRES_DATABASE="[db_name]"
POSTGRES_PRISMA_URL="postgresql://[user]:[password]@[host]-pooler.[region].aws.neon.tech/[db_name]?sslmode=require&connect_timeout=15"

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email
RESEND_API_KEY=re_...
EMAIL_FROM="POLUTEK.PL <no-reply@polutek.pl>"

# App Config
APP_ENV=development
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=admin@polutek.pl

# Enables hidden experimental campaign/zrzutka page
ENABLE_CAMPAIGN_PAGE=false

# Reserved for future multi-creator features
ENABLE_MULTI_CREATOR=false

# Demo content fallback. Enable for first run / demo. Opt-in only.
ENABLE_DEMO_FALLBACKS=false

# Security
HEALTHCHECK_TOKEN=your_secure_token

# Rate Limiting (Upstash/KV)
# Required in production for /api/media and /api/checkout/create-intent.
# Without these, endpoints will return a controlled 503 error.
# Memory fallback is allowed only in development/test.
UPSTASH_REDIS_REST_URL="https://your-host.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# Vercel KV / Redis Integration (optional aliases)
KV_REST_API_URL="https://your-host.upstash.io"
KV_REST_API_TOKEN="your-token"
KV_REST_API_READ_ONLY_TOKEN="your-readonly-token"
KV_URL="rediss://default:your-token@your-host.upstash.io:6379"
REDIS_URL="rediss://default:your-token@your-host.upstash.io:6379"

# Media Bucket / CDN host allowlist for /api/media and comment image attachments.
# Use exact controlled hosts only (for example a specific bucket host or CDN CNAME).
# Do not put broad provider domains such as r2.dev, r2.cloudflarestorage.com, or vercel-storage.com. HTTPS is required.
MEDIA_BUCKET_HOST=your-bucket.r2.dev
NEXT_PUBLIC_R2_PUBLIC_HOST=cdn.yourdomain.com
NEXT_PUBLIC_BLOB_PUBLIC_HOST=your-project.public.blob.vercel-storage.com
ALLOWED_MEDIA_HOSTS=cdn.yourdomain.com,your-bucket.r2.dev
